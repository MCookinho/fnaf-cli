                     "$ASSETS_DIR/office_outage_freddy.ans" "$ASSETS_DIR/office_outage_half.ans"; do
                cat "$f" 2>/dev/null || true
                [[ -f "$TEMP_DIR/STOP" ]] && exit 0
                sleep 0.1
            done
        done
    ) &
    local ofp=$!

    sleep $((RANDOM % 9 + 11))
    touch "$TEMP_DIR/STOP" 2>/dev/null || true
    sleep 1
    rm -f "$TEMP_DIR/STOP" 2>/dev/null || true
    kill $ofp 2>/dev/null || true
    audio_stop "musicbox"
    cat "$ASSETS_DIR/office_outage.ans" 2>/dev/null || true
    [[ -f "$PROJECT_DIR/WIN" ]] && win_game || { JUMPSCARE="_freddy"; game_over; }
}

game_over() {
    pkill -f "fnaf-cli.*events" 2>/dev/null || true
    audio_stop "fan"; audio_stop "fan2"; rm -f "$PROJECT_DIR/SEEN_FOXY" 2>/dev/null || true
    audio_start "XSCREAM.mp3" "sfx" "false" 100
    cat "$ASSETS_DIR/jumpscare${JUMPSCARE}.ans" 2>/dev/null || true
    audio_stop "ambience"; audio_stop "voiceover"; audio_stop "oven"; audio_stop "golden"
    rm -f "$PROJECT_DIR/office_states" "$PROJECT_DIR/cams_state" "$PROJECT_DIR/MOVEMENTS.cmd" \
          "$PROJECT_DIR/refresh" "$PROJECT_DIR/SEEN_FOXY" "$PROJECT_DIR/BATTERY" \
          "$PROJECT_DIR/TIME" "$PROJECT_DIR/saw_freddy" "$PROJECT_DIR/saw_cams"  2>/dev/null || true
    sleep 4
    cat "$ASSETS_DIR/gameover.ans" 2>/dev/null || true
    sleep 9
    main
}

