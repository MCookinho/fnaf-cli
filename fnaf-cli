    rnd=$((RANDOM % 2 + 1))
    [[ $rnd -eq 1 ]] && { audio_start "running_fast3.mp3" "sfx" "false" 22; sleep 3; }
    audio_start "deepsteps.mp3" "sfx" "false" 22; sleep 7
    audio_start "musicbox.mp3" "musicbox" "false" 90

    (
        while true; do
            for f in "$ASSETS_DIR/office_outage_freddy.ans" "$ASSETS_DIR/office_outage_half.ans" \
